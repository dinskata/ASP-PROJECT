@model ASP_PROJECT.Models.ViewModels.AnnouncementEditViewModel

<div class="col-md-8">
    <label asp-for="Title" class="form-label"></label>
    <input asp-for="Title" class="form-control" />
    <span asp-validation-for="Title" class="text-danger"></span>
</div>
<div class="col-md-4">
    <label asp-for="Audience" class="form-label"></label>
    <input asp-for="Audience" class="form-control" placeholder="All" />
    <span asp-validation-for="Audience" class="text-danger"></span>
</div>
<div class="col-md-6">
    <label asp-for="PublishedOnUtc" class="form-label"></label>
    <input asp-for="PublishedOnUtc" class="form-control" />
    <span asp-validation-for="PublishedOnUtc" class="text-danger"></span>
</div>
<div class="col-md-6">
    <div class="editor-publish-row h-100">
        <div>
            <label asp-for="IsPinned" class="form-check-label fw-semibold"></label>
            <div class="small text-secondary">Pinned updates appear first in the public announcements feed and on the homepage ticker.</div>
        </div>
        <div class="form-check form-switch m-0">
            <input asp-for="IsPinned" class="form-check-input" />
        </div>
    </div>
</div>
<div class="col-12">
    <label asp-for="Content" class="form-label"></label>
    <textarea asp-for="Content" class="form-control" rows="8"></textarea>
    <span asp-validation-for="Content" class="text-danger"></span>
</div>

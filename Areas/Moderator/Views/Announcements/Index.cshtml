@using ASP_PROJECT.Data
@model IReadOnlyCollection<ASP_PROJECT.Models.ViewModels.AnnouncementManagementItemViewModel>
@{
    ViewData["Title"] = "Announcements";
    var isAdmin = User.IsInRole(DbInitializer.AdministratorRole);
}

<section class="section-space">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="section-label">Updates</span>
                <h1>Manage announcements</h1>
                <p class="text-secondary mb-0">Create and refine platform-wide updates for visitors, attendees, and partners.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @if (isAdmin)
                {
                    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Back to admin panel</a>
                }
                else
                {
                    <a class="btn btn-outline-secondary" asp-area="Moderator" asp-controller="Dashboard" asp-action="Index">Back to moderator panel</a>
                }
                <a class="btn btn-primary" asp-action="Create">Create announcement</a>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Audience</th>
                                    <th>Published</th>
                                    <th>Placement</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.Title</div>
                                            <div class="small text-secondary">@item.ContentPreview</div>
                                        </td>
                                        <td>@item.Audience</td>
                                        <td>@item.PublishedOnUtc.ToLocalTime().ToString("g")</td>
                                        <td>@(item.IsPinned ? "Pinned" : "Recent")</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="mb-0 text-secondary">No announcements have been created yet.</p>
                }
            </div>
        </div>
    </div>
</section>

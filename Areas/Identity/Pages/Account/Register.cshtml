@page
@model ASP_PROJECT.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-shell">
    <div class="container">
        <div class="auth-grid">
            <div class="auth-copy">
                <span class="section-label">Create your account</span>
                <h1>Join Eventure and start booking sessions.</h1>
                <p>Create an individual account to register for events, track your participation, and leave reviews after attending.</p>
                <div class="auth-points">
                    <div class="auth-point"><strong>Quick registration</strong><span>Simple signup flow with validation.</span></div>
                    <div class="auth-point"><strong>Safer forms</strong><span>Identity, antiforgery protection, and encoded output.</span></div>
                    <div class="auth-point"><strong>Ready for roles</strong><span>Accounts can be upgraded for administration.</span></div>
                </div>
            </div>
            <div class="auth-card">
                <div class="auth-card-header">
                    <h2>Register</h2>
                    <p>Fill in your details to create an account.</p>
                </div>
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="vstack gap-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <div>
                        <label asp-for="Input.FullName" class="form-label"></label>
                        <input asp-for="Input.FullName" class="form-control" autocomplete="name" />
                        <span asp-validation-for="Input.FullName" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Input.Password" class="form-label"></label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                    <button id="registerSubmit" type="submit" class="btn btn-primary btn-lg w-100">Create account</button>
                    <div class="auth-links">
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Already have an account? Log in</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model ASP_PROJECT.Models.ViewModels.VenueStaffCreateViewModel
@{
    ViewData["Title"] = "Add Venue Staff";
}

<section class="section-space">
    <div class="container narrow-content">
        <div class="section-heading">
            <div>
                <span class="section-label">Venue management</span>
                <h1>Add venue staff</h1>
                <p class="text-secondary mb-0">Create a staff login and choose which of your venues that account can support.</p>
            </div>
        </div>

        <form method="post" class="card border-0 shadow-sm p-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-4">
                <h2 class="h5">Venue access</h2>
                <p class="text-secondary small">This staff account will only be able to work with the venues you select below.</p>
                <div class="row g-2">
                    @for (var i = 0; i < Model.AvailableVenues.Count; i++)
                    {
                        <div class="col-md-6">
                            <div class="form-check">
                                <input asp-for="AvailableVenues[i].IsSelected" class="form-check-input" />
                                <input asp-for="AvailableVenues[i].Id" type="hidden" />
                                <input asp-for="AvailableVenues[i].Name" type="hidden" />
                                <input asp-for="AvailableVenues[i].City" type="hidden" />
                                <label class="form-check-label" asp-for="AvailableVenues[i].IsSelected">@Model.AvailableVenues[i].Name, @Model.AvailableVenues[i].City</label>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex gap-3 mt-4">
                <button class="btn btn-primary">Create staff account</button>
                <a class="btn btn-outline-secondary" asp-area="Manager" asp-controller="VenueStaff" asp-action="Index">Back</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

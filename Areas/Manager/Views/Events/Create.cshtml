@model ASP_PROJECT.Models.ViewModels.EventEditViewModel
@{
    ViewData["Title"] = "Create Event";
}

<section class="section-space">
    <div class="container editor-shell">
        <div class="section-heading editor-page-heading mb-4">
            <div>
                <span class="section-label">Venue management</span>
                <h1>Create event</h1>
                <p class="text-secondary mb-0">You can create events only for the venues currently assigned to your account.</p>
            </div>
        </div>
        <form method="post" class="card border-0 shadow-sm editor-card p-4">
            @Html.AntiForgeryToken()
            <partial name="~/Views/Shared/_EventForm.cshtml" model="Model" />
            <div class="d-flex gap-3 mt-4 editor-actions">
                <button class="btn btn-primary">Save</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

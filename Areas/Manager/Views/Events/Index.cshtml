@model IReadOnlyCollection<ASP_PROJECT.Models.ViewModels.ManagementEventListItemViewModel>
@{
    ViewData["Title"] = "Manage My Events";
}

<section class="section-space">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="section-label">Venue management</span>
                <h1>My events</h1>
            </div>
            <a class="btn btn-primary" asp-action="Create">Create event</a>
        </div>
        <form method="get" class="card border-0 shadow-sm p-3 mb-4">
            <div class="row g-3">
                <div class="col-md-10">
                    <input name="searchTerm" value="@Context.Request.Query["searchTerm"]" class="form-control" placeholder="Search by title, category, or venue" />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary">Search</button>
                </div>
            </div>
        </form>
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Venue</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Tickets Sold</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.Venue</td>
                                    <td>@item.StartsAtUtc.ToLocalTime().ToString("g")</td>
                                    <td>@(item.IsPublished ? "Published" : "Draft")</td>
                                    <td>@item.TicketsSold</td>
                                    <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

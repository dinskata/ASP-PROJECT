@model ASP_PROJECT.Models.ViewModels.EventEditViewModel
@{
    ViewData["Title"] = "Edit Event";
}

<section class="section-space">
    <div class="container narrow-content">
        <div class="section-heading mb-4">
            <div>
                <span class="section-label">Venue management</span>
                <h1>Edit event</h1>
                <p class="text-secondary mb-0">This editor is limited to events connected to the venues you manage.</p>
            </div>
        </div>
        <form method="post" class="card border-0 shadow-sm editor-card p-4">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <partial name="~/Views/Shared/_EventForm.cshtml" model="Model" />
            <div class="d-flex gap-3 mt-4">
                <button class="btn btn-primary">Update</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model ASP_PROJECT.Models.ViewModels.UserAdminEditViewModel
@{
    ViewData["Title"] = "Edit User";
}

<section class="section-space">
    <div class="container narrow-content">
        <h1>Manage user</h1>
        <form method="post" class="card border-0 shadow-sm p-4">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="vstack gap-3">
                <div>
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="row g-3">
                    <div class="col-md-6"><div class="form-check"><input asp-for="IsBuyer" class="form-check-input" /><label asp-for="IsBuyer" class="form-check-label">Buyer</label></div></div>
                    <div class="col-md-6"><div class="form-check"><input asp-for="IsVenueManager" class="form-check-input" /><label asp-for="IsVenueManager" class="form-check-label">Venue manager</label></div></div>
                    <div class="col-md-6"><div class="form-check"><input asp-for="IsVenueStaff" class="form-check-input" /><label asp-for="IsVenueStaff" class="form-check-label">Venue staff</label></div></div>
                    <div class="col-md-6"><div class="form-check"><input asp-for="IsSiteModerator" class="form-check-input" /><label asp-for="IsSiteModerator" class="form-check-label">Site moderator</label></div></div>
                    <div class="col-md-6"><div class="form-check"><input asp-for="IsAdministrator" class="form-check-input" /><label asp-for="IsAdministrator" class="form-check-label">Administrator</label></div></div>
                </div>
                <div>
                    <label class="form-label">Assigned venues for venue manager access</label>
                    <div class="row g-2">
                        @for (var i = 0; i < Model.AvailableVenues.Count; i++)
                        {
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input asp-for="AvailableVenues[i].IsSelected" class="form-check-input" />
                                    <input asp-for="AvailableVenues[i].Id" type="hidden" />
                                    <input asp-for="AvailableVenues[i].Name" type="hidden" />
                                    <input asp-for="AvailableVenues[i].City" type="hidden" />
                                    <label class="form-check-label" asp-for="AvailableVenues[i].IsSelected">@Model.AvailableVenues[i].Name, @Model.AvailableVenues[i].City</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 mt-4">
                <button class="btn btn-primary">Save changes</button>
                <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Back to admin panel</a>
                <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

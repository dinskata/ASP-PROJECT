@model IReadOnlyCollection<ASP_PROJECT.Models.ViewModels.UserAdminListItemViewModel>
@{
    ViewData["Title"] = "Manage Users";
}

<section class="section-space">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="section-label">Administration</span>
                <h1>Users and roles</h1>
            </div>
            <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Back to admin panel</a>
        </div>
        <form method="get" class="card border-0 shadow-sm p-3 mb-4">
            <div class="row g-3">
                <div class="col-md-7">
                    <input name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by name, email, or role" />
                </div>
                <div class="col-md-3">
                    <select name="sortBy" class="form-select">
                        <option value="name" selected="@(ViewBag.SortBy == "name")">Name A-Z</option>
                        <option value="name_desc" selected="@(ViewBag.SortBy == "name_desc")">Name Z-A</option>
                        <option value="email" selected="@(ViewBag.SortBy == "email")">Email A-Z</option>
                        <option value="created_desc" selected="@(ViewBag.SortBy == "created_desc")">Newest accounts</option>
                        <option value="created" selected="@(ViewBag.SortBy == "created")">Oldest accounts</option>
                        <option value="venues_desc" selected="@(ViewBag.SortBy == "venues_desc")">Most venue assignments</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary">Apply</button>
                </div>
            </div>
        </form>
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Roles</th>
                                <th>Assigned Venues</th>
                                <th>Created</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td><a asp-action="Details" asp-route-id="@user.Id">@user.FullName</a></td>
                                    <td>@user.Email</td>
                                    <td>@user.RolesDisplay</td>
                                    <td>@user.AssignedVenuesCount</td>
                                    <td>@user.CreatedOnUtc.ToLocalTime().ToString("g")</td>
                                    <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@user.Id">Manage</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

@model ASP_PROJECT.Models.ViewModels.AdminTicketEditViewModel
@{
    ViewData["Title"] = "Edit Ticket";
}

<section class="section-space">
    <div class="container narrow-content">
        <h1>Edit ticket</h1>
        <form method="post" class="card border-0 shadow-sm p-4">
            @Html.AntiForgeryToken()
            <input asp-for="TicketId" type="hidden" />
            <input asp-for="RegistrationId" type="hidden" />
            <input asp-for="UserId" type="hidden" />
            <input asp-for="BuyerName" type="hidden" />
            <input asp-for="EventTitle" type="hidden" />
            <input asp-for="VenueName" type="hidden" />
            <input asp-for="StartsAtUtc" type="hidden" />
            <input asp-for="TicketCode" type="hidden" />
            <input asp-for="VerificationCode" type="hidden" />
            <input asp-for="PaymentStatus" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="detail-grid mb-4">
                <div><strong>Buyer</strong><span>@Model.BuyerName</span></div>
                <div><strong>Event</strong><span>@Model.EventTitle</span></div>
                <div><strong>Venue</strong><span>@Model.VenueName</span></div>
                <div><strong>Starts</strong><span>@Model.StartsAtUtc.ToLocalTime().ToString("f")</span></div>
                <div><strong>Ticket code</strong><span>@Model.TicketCode</span></div>
                <div><strong>Verification</strong><span>@Model.VerificationCode</span></div>
            </div>

            <div class="vstack gap-3">
                <div>
                    <label asp-for="SeatLabel" class="form-label"></label>
                    <input asp-for="SeatLabel" class="form-control" />
                    <span asp-validation-for="SeatLabel" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="TicketNote" class="form-label">Ticket note</label>
                    <textarea asp-for="TicketNote" class="form-control" rows="4" placeholder="Optional admin note shown on the ticket"></textarea>
                    <span asp-validation-for="TicketNote" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-3 mt-4">
                <button class="btn btn-primary">Save ticket changes</button>
                <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Back to admin panel</a>
                <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.UserId">Back to user</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

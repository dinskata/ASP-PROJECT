@model IReadOnlyCollection<ASP_PROJECT.Models.ViewModels.ManagementEventListItemViewModel>
@{
    ViewData["Title"] = "Manage Events";
}

<section class="section-space">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="section-label">Administration</span>
                <h1>Manage events</h1>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Back to admin panel</a>
                <a class="btn btn-primary" asp-action="Create">Create new</a>
            </div>
        </div>
        <form method="get" class="card border-0 shadow-sm p-3 mb-4">
            <div class="row g-3">
                <div class="col-md-5">
                    <input name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by title, category, or venue" />
                </div>
                <div class="col-md-3">
                    <select name="statusFilter" class="form-select">
                        <option value="all" selected="@(ViewBag.StatusFilter == "all")">All statuses</option>
                        <option value="published" selected="@(ViewBag.StatusFilter == "published")">Published</option>
                        <option value="draft" selected="@(ViewBag.StatusFilter == "draft")">Draft</option>
                        <option value="upcoming" selected="@(ViewBag.StatusFilter == "upcoming")">Upcoming</option>
                        <option value="ended" selected="@(ViewBag.StatusFilter == "ended")">Ended</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="date" selected="@(ViewBag.SortBy == "date")">Date ascending</option>
                        <option value="date_desc" selected="@(ViewBag.SortBy == "date_desc")">Date descending</option>
                        <option value="title" selected="@(ViewBag.SortBy == "title")">Title A-Z</option>
                        <option value="title_desc" selected="@(ViewBag.SortBy == "title_desc")">Title Z-A</option>
                        <option value="tickets_desc" selected="@(ViewBag.SortBy == "tickets_desc")">Most tickets sold</option>
                        <option value="reviews_desc" selected="@(ViewBag.SortBy == "reviews_desc")">Most reviews</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary">Search</button>
                </div>
            </div>
        </form>
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Date</th>
                                <th>Venue</th>
                                <th>Status</th>
                                <th>Tickets Sold</th>
                                <th>Reviews</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.Category</td>
                                    <td>@item.StartsAtUtc.ToLocalTime().ToString("g")</td>
                                    <td>@item.Venue</td>
                                    <td>@(item.IsPublished ? "Published" : "Draft")</td>
                                    <td>@item.TicketsSold</td>
                                    <td>@item.ReviewCount</td>
                                    <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

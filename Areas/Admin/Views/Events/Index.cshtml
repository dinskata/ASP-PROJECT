@model ASP_PROJECT.Models.ViewModels.EventListViewModel
@{
    ViewData["Title"] = "Manage Events";
}

<section class="section-space">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="section-label">Administration</span>
                <h1>Manage events</h1>
            </div>
            <a class="btn btn-primary" asp-action="Create">Create new</a>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Date</th>
                                <th>Venue</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Result.Items)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.Category</td>
                                    <td>@item.StartsAtUtc.ToLocalTime().ToString("g")</td>
                                    <td>@item.Venue</td>
                                    <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

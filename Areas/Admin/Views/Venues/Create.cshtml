@model ASP_PROJECT.Models.ViewModels.VenueEditViewModel
@{
    ViewData["Title"] = "Create Venue";
}

<section class="section-space">
    <div class="container narrow-content">
        <div class="section-heading mb-4">
            <div>
                <span class="section-label">Administration</span>
                <h1>Create venue</h1>
                <p class="text-secondary mb-0">Add a new venue profile with enough detail for both managers and attendees.</p>
            </div>
        </div>
        <form method="post" class="card border-0 shadow-sm editor-card p-4">
            @Html.AntiForgeryToken()
            <partial name="~/Views/Shared/_VenueForm.cshtml" model="Model" />
            <div class="d-flex gap-3 mt-4">
                <button class="btn btn-primary">Create</button>
                <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Back to admin panel</a>
                <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model ASP_PROJECT.Models.ViewModels.TicketVerificationPageViewModel
@{
    ViewData["Title"] = "Ticket Verification";
}

<section class="section-space">
    <div class="container narrow-content">
        <div class="section-heading">
            <div>
                <span class="section-label">Verification</span>
                <h1>Check ticket legitimacy</h1>
            </div>
        </div>
        <form method="post" class="card border-0 shadow-sm p-4 mb-4" id="ticketVerificationForm">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="TicketCode" class="form-label">Ticket code</label>
                    <input asp-for="TicketCode" class="form-control" placeholder="REG00001-EV0001-T01" id="ticketCodeInput" />
                </div>
                <div class="col-md-6">
                    <label asp-for="VerificationCode" class="form-label">Verification code</label>
                    <input asp-for="VerificationCode" class="form-control text-uppercase" placeholder="12-character code" id="verificationCodeInput" />
                </div>
            </div>
            <div class="d-flex gap-3 mt-4">
                <button class="btn btn-primary">Verify ticket</button>
                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#demoScannerModal">Demo QR scanner</button>
            </div>
        </form>

        <div class="modal fade" id="demoScannerModal" tabindex="-1" aria-labelledby="demoScannerModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <div>
                            <span class="section-label">Scanner demo</span>
                            <h2 class="modal-title fs-4 mb-0" id="demoScannerModalLabel">Simulate QR scanning</h2>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="demo-scanner-stage mb-4">
                            <div class="demo-scanner-frame">
                                <div class="demo-scanner-line"></div>
                                <span class="demo-scanner-corner demo-scanner-corner-top-left"></span>
                                <span class="demo-scanner-corner demo-scanner-corner-top-right"></span>
                                <span class="demo-scanner-corner demo-scanner-corner-bottom-left"></span>
                                <span class="demo-scanner-corner demo-scanner-corner-bottom-right"></span>
                            </div>
                            <p class="text-secondary small mb-0">Pick one of the recent demo tickets below to simulate a QR scan and auto-fill the verification form.</p>
                        </div>

                        <div class="demo-scan-list">
                            @if (!Model.DemoTickets.Any())
                            {
                                <div class="demo-scan-item">
                                    <div>
                                        <strong>No demo tickets available</strong>
                                        <div class="small text-secondary">This account does not currently have access to any active venue tickets.</div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                @foreach (var ticket in Model.DemoTickets)
                                {
                                    <div class="demo-scan-item">
                                        <div>
                                            <strong>@ticket.EventTitle</strong>
                                            <div class="small text-secondary">@ticket.BuyerName &middot; @ticket.SeatLabel &middot; @ticket.PaymentStatus</div>
                                            <div class="small text-secondary">@ticket.TicketCode / @ticket.VerificationCode</div>
                                        </div>
                                        <button
                                            type="button"
                                            class="btn btn-sm btn-primary demo-scan-trigger"
                                            data-ticket-code="@ticket.TicketCode"
                                            data-verification-code="@ticket.VerificationCode">
                                            Scan demo QR
                                        </button>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Result?.IsSubmitted == true)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                        <div>
                            <span class="section-label">Verification result</span>
                            <h2 class="h4 mb-0">@(Model.Result.IsValid ? "Ticket accepted" : Model.Result.IsCheckedIn ? "Ticket already checked in" : "Ticket not valid")</h2>
                        </div>
                        <span class="badge @(Model.Result.IsValid ? "text-bg-success" : Model.Result.IsCheckedIn ? "text-bg-warning" : "text-bg-danger")">
                            @(Model.Result.IsValid ? "Valid" : Model.Result.IsCheckedIn ? "Used" : "Rejected")
                        </span>
                    </div>
                    <p class="text-secondary">@Model.Result.Message</p>

                    <div class="detail-grid">
                        <div><strong>Ticket code</strong><span>@Model.Result.TicketCode</span></div>
                        <div><strong>Verification code</strong><span>@Model.Result.VerificationCode</span></div>
                        <div><strong>Buyer</strong><span>@(string.IsNullOrWhiteSpace(Model.Result.BuyerName) ? "-" : Model.Result.BuyerName)</span></div>
                        <div><strong>Event</strong><span>@(string.IsNullOrWhiteSpace(Model.Result.EventTitle) ? "-" : Model.Result.EventTitle)</span></div>
                        <div><strong>Venue</strong><span>@(string.IsNullOrWhiteSpace(Model.Result.VenueName) ? "-" : Model.Result.VenueName)</span></div>
                        <div><strong>Seat</strong><span>@(string.IsNullOrWhiteSpace(Model.Result.SeatLabel) ? "-" : Model.Result.SeatLabel)</span></div>
                        <div><strong>Status</strong><span>@(string.IsNullOrWhiteSpace(Model.Result.PaymentStatus) ? "-" : Model.Result.PaymentStatus)</span></div>
                        <div><strong>Starts</strong><span>@(Model.Result.StartsAtUtc?.ToLocalTime().ToString("f") ?? "-")</span></div>
                        <div><strong>Checked in</strong><span>@(Model.Result.IsCheckedIn ? "Yes" : "No")</span></div>
                        <div><strong>Checked by</strong><span>@(string.IsNullOrWhiteSpace(Model.Result.CheckedInByName) ? "-" : Model.Result.CheckedInByName)</span></div>
                        <div><strong>Checked on</strong><span>@(Model.Result.CheckedInOnUtc?.ToLocalTime().ToString("f") ?? "-")</span></div>
                    </div>

                    @if (Model.Result.CanMarkCheckedIn)
                    {
                        <form method="post" asp-action="CheckIn" class="mt-4">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketCode" value="@Model.Result.TicketCode" />
                            <button class="btn btn-success">Mark ticket as checked</button>
                        </form>
                    }
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <span class="section-label">Ticket list</span>
                        <h2 class="h4 mb-0">Recent accessible tickets</h2>
                    </div>
                    <p class="text-secondary small mb-0">Managers and venue staff only see tickets for their assigned venues. Moderators and admins see the wider list.</p>
                </div>

                @if (!Model.RecentTickets.Any())
                {
                    <div class="empty-state py-4">
                        <h3>No tickets available</h3>
                        <p>There are no active tickets in the venues this account can access right now.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Ticket</th>
                                    <th>Buyer</th>
                                    <th>Event</th>
                                    <th>Venue</th>
                                    <th>Seat</th>
                                    <th>Status</th>
                                    <th>Check-in</th>
                                    <th>Starts</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in Model.RecentTickets)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@ticket.TicketCode</div>
                                            <div class="small text-secondary">@ticket.VerificationCode</div>
                                        </td>
                                        <td>@ticket.BuyerName</td>
                                        <td>@ticket.EventTitle</td>
                                        <td>@ticket.VenueName</td>
                                        <td>@ticket.SeatLabel</td>
                                        <td>@ticket.PaymentStatus</td>
                                        <td>
                                            @if (ticket.IsCheckedIn)
                                            {
                                                <span class="text-success fw-semibold">Checked</span>
                                            }
                                            else
                                            {
                                                <span class="text-secondary small">Open</span>
                                            }
                                        </td>
                                        <td>@ticket.StartsAtUtc.ToLocalTime().ToString("g")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <span class="section-label">Check-in history</span>
                        <h2 class="h4 mb-0">Recently checked tickets</h2>
                    </div>
                    <p class="text-secondary small mb-0">This history follows the same venue access rules as the verifier itself.</p>
                </div>

                @{
                    var checkedTickets = Model.RecentTickets
                        .Where(x => x.IsCheckedIn)
                        .OrderByDescending(x => x.CheckedInOnUtc)
                        .ToList();
                }

                @if (!checkedTickets.Any())
                {
                    <div class="empty-state py-4">
                        <h3>No checked tickets yet</h3>
                        <p>Checked-in tickets will appear here after staff or managers admit attendees.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Ticket</th>
                                    <th>Buyer</th>
                                    <th>Event</th>
                                    <th>Seat</th>
                                    <th>Checked by</th>
                                    <th>Checked on</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in checkedTickets)
                                {
                                    <tr>
                                        <td>@ticket.TicketCode</td>
                                        <td>@ticket.BuyerName</td>
                                        <td>
                                            <div>@ticket.EventTitle</div>
                                            <small class="text-secondary">@ticket.VenueName</small>
                                        </td>
                                        <td>@ticket.SeatLabel</td>
                                        <td>@(string.IsNullOrWhiteSpace(ticket.CheckedInByName) ? "-" : ticket.CheckedInByName)</td>
                                        <td>@(ticket.CheckedInOnUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('ticketVerificationForm');
            const ticketCodeInput = document.getElementById('ticketCodeInput');
            const verificationCodeInput = document.getElementById('verificationCodeInput');
            const demoScannerModal = document.getElementById('demoScannerModal');

            if (!form || !ticketCodeInput || !verificationCodeInput || !demoScannerModal) {
                return;
            }

            demoScannerModal.addEventListener('click', (event) => {
                const trigger = event.target.closest('.demo-scan-trigger');
                if (!trigger) {
                    return;
                }

                ticketCodeInput.value = trigger.getAttribute('data-ticket-code') || '';
                verificationCodeInput.value = trigger.getAttribute('data-verification-code') || '';

                const modal = bootstrap.Modal.getInstance(demoScannerModal);
                modal?.hide();
                form.requestSubmit();
            });
        })();
    </script>
}

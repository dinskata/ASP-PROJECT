@model ASP_PROJECT.Models.ViewModels.PagedResult<ASP_PROJECT.Models.ViewModels.VenueListItemViewModel>
@{
    ViewData["Title"] = "Venues";
    ViewData["Action"] = "Index";
    ViewData["Controller"] = "Venues";
    ViewData["RouteValues"] = new Dictionary<string, string>
    {
        ["searchTerm"] = ViewBag.SearchTerm?.ToString() ?? string.Empty
    };
}

<section class="section-space">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="section-label">Spaces</span>
                <h1>Venues</h1>
            </div>
        </div>
        <form method="get" class="card border-0 shadow-sm p-3 mb-4">
            <div class="row g-3">
                <div class="col-md-10">
                    <input name="searchTerm" class="form-control" value="@ViewBag.SearchTerm" placeholder="Search by venue or city" />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary">Search</button>
                </div>
            </div>
        </form>
        <div class="row g-4">
            @foreach (var venue in Model.Items)
            {
                <div class="col-md-6 col-xl-4">
                    <article class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h5>@venue.Name</h5>
                            <p class="text-secondary mb-2">@venue.City</p>
                            <p class="small mb-3">@venue.Address</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-semibold">Capacity: @venue.Capacity</div>
                                    <small class="text-secondary">
                                        @venue.EventCount event(s)
                                        @if (venue.ReviewCount > 0)
                                        {
                                            <text> • @venue.AverageRating.ToString("F1")/5 venue rating from @venue.ReviewCount review(s)</text>
                                        }
                                        else
                                        {
                                            <text> • No venue reviews yet</text>
                                        }
                                    </small>
                                </div>
                                <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@venue.Id">Details</a>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
        <partial name="_PagedNavigation" model="Model" />
    </div>
</section>

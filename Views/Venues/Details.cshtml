@model ASP_PROJECT.Models.ViewModels.VenueDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}

<section class="section-space">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-4">
                <span class="section-label">@Model.City</span>
                <h1>@Model.Name</h1>
                <p class="text-secondary">@Model.Description</p>
                <div class="detail-grid">
                    <div><strong>Address</strong><span>@Model.Address</span></div>
                    <div><strong>Capacity</strong><span>@Model.Capacity attendees</span></div>
                    <div>
                        <strong>Venue rating</strong>
                        <span>
                            @(Model.ReviewCount == 0
                                ? "No ratings yet"
                                : $"{Model.AverageRating:F1}/5 from {Model.ReviewCount} review{(Model.ReviewCount == 1 ? string.Empty : "s")}")
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <h2 class="h4 mb-3">Upcoming events</h2>
                @if (Model.UpcomingEvents.Any())
                {
                    <div class="row g-4">
                        @foreach (var item in Model.UpcomingEvents)
                        {
                            <div class="col-md-6">
                                <partial name="_EventCard" model="item" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="card border-0 shadow-sm p-4">
                        <p class="text-secondary mb-0">There are no upcoming events scheduled for this venue right now.</p>
                    </div>
                }

                <h2 class="h4 mt-5 mb-3">Ended events</h2>
                @if (Model.EndedEvents.Any())
                {
                    <div class="row g-4">
                        @foreach (var item in Model.EndedEvents)
                        {
                            <div class="col-md-6">
                                <partial name="_EventCard" model="item" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="card border-0 shadow-sm p-4">
                        <p class="text-secondary mb-0">No ended events are available for this venue yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

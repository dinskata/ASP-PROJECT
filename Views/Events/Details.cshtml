@model ASP_PROJECT.Models.ViewModels.EventDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="section-space">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-8">
                <span class="section-label">@Model.Category</span>
                <h1>@Model.Title</h1>
                <p class="lead text-secondary">@Model.Description</p>
                <div class="detail-grid my-4">
                    <div><strong>Date</strong><span>@Model.StartsAtUtc.ToLocalTime().ToString("f")</span></div>
                    <div>
                        <strong>Starts in</strong>
                        <span class="event-start-countdown" data-starts-at="@Model.StartsAtUtc.ToString("O")" data-has-ended="@Model.HasEnded.ToString().ToLowerInvariant()">
                            @(Model.HasEnded ? "Event ended" : "Calculating...")
                        </span>
                        <small class="text-secondary d-block mt-1">Live countdown until the event begins.</small>
                    </div>
                    <div><strong>Venue</strong><span>@Model.Venue</span></div>
                    <div><strong>Address</strong><span>@Model.VenueAddress, @Model.City</span></div>
                    <div><strong>Duration</strong><span>@Model.DurationMinutes min</span></div>
                    <div><strong>Price</strong><span>@(Model.Price == 0 ? "Free" : $"EUR {Model.Price:F2}")</span></div>
                    <div><strong>Seats left</strong><span>@Model.SeatsAvailable</span></div>
                </div>

                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-body">
                        <h3 class="h5">Reviews</h3>
                        <p class="text-secondary">Average rating: @Model.AverageRating.ToString("F1") / 5 from @Model.ReviewCount review(s).</p>
                        @if (Model.Reviews.Any())
                        {
                            foreach (var review in Model.Reviews)
                            {
                                <div class="review-item">
                                    <div class="d-flex justify-content-between flex-wrap gap-2">
                                        <strong>@review.AuthorName</strong>
                                        <span class="text-secondary">@review.CreatedOnUtc.ToLocalTime().ToString("dd MMM yyyy")</span>
                                    </div>
                                    <div class="small text-warning">Rating: @review.Rating / 5</div>
                                    <p class="mb-0">@review.Comment</p>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="mb-0 text-secondary">No reviews yet.</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h3 class="h5">Purchase tickets</h3>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="vstack gap-3">
                                <div>
                                    <label class="form-label" for="tickets">Tickets</label>
                                    <input class="form-control" type="number" min="1" max="10" step="1" required id="tickets" name="Tickets" value="1" form="purchaseForm" />
                                </div>
                                @if (Model.Price > 0)
                                {
                                    <p class="mb-0 text-secondary small">Total will be calculated at @Model.Price.ToString("F2") per ticket during checkout.</p>
                                }
                                else
                                {
                                    <p class="mb-0 text-secondary small">This event is free, but a completed checkout is still required to reserve your place.</p>
                                }
                                @if (Model.HasEnded)
                                {
                                    <button type="button" class="btn btn-primary" disabled>Open checkout</button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#purchaseModal">Open checkout</button>
                                }
                            </div>

                            <div class="modal fade" id="purchaseModal" tabindex="-1" aria-labelledby="purchaseModalLabel" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h2 class="modal-title fs-5" id="purchaseModalLabel">Checkout</h2>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            <p class="text-secondary small mb-3">Use the test buttons below to simulate a successful or failed payment. Card details are demo-only.</p>
                                            <form asp-action="Register" method="post" class="vstack gap-3" id="purchaseForm">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="EventId" value="@Model.Id" />
                                                <input type="hidden" name="Tickets" value="1" id="modalTicketsMirror" />
                                                <input type="hidden" name="PaymentDecision" id="paymentDecision" value="" />
                                                <div class="text-danger small d-none" id="purchaseValidationMessage">Please complete the checkout form correctly before continuing.</div>
                                                <div>
                                                    <label class="form-label" for="cardholderName">Cardholder name</label>
                                                    <input class="form-control" type="text" id="cardholderName" name="CardholderName" value="Alex Petrova" autocomplete="cc-name" minlength="3" maxlength="80" required />
                                                </div>
                                                <div>
                                                    <label class="form-label" for="cardNumber">Card number</label>
                                                    <input class="form-control" type="text" inputmode="numeric" id="cardNumber" name="CardNumber" value="4242424242424242" maxlength="16" pattern="\d{16}" autocomplete="cc-number" required />
                                                </div>
                                                <div class="row g-3">
                                                    <div class="col-4">
                                                        <label class="form-label" for="expiryMonth">Month</label>
                                                        <input class="form-control" type="number" min="1" max="12" id="expiryMonth" name="ExpiryMonth" value="12" required />
                                                    </div>
                                                    <div class="col-4">
                                                        <label class="form-label" for="expiryYear">Year</label>
                                                        <input class="form-control" type="number" min="2026" max="2100" id="expiryYear" name="ExpiryYear" value="2030" required />
                                                    </div>
                                                    <div class="col-4">
                                                        <label class="form-label" for="cvv">CVV</label>
                                                        <input class="form-control" type="password" inputmode="numeric" id="cvv" name="Cvv" value="123" maxlength="4" pattern="\d{3,4}" autocomplete="cc-csc" required />
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="button" class="btn btn-outline-danger" data-payment-decision="denied">Payment denied test</button>
                                            <button type="button" class="btn btn-primary" data-payment-decision="accepted">Payment accepted test</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            @if (Model.HasEnded)
                            {
                                <p class="text-secondary small mt-3 mb-0">Ticket sales are closed because this event has already ended.</p>
                            }
                        }
                        else
                        {
                            <p class="text-secondary">Sign in to purchase tickets and leave reviews after attending.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const formatCountdown = (target, hasEnded) => {
                const difference = target.getTime() - Date.now();

                if (difference <= 0) {
                    return hasEnded ? 'Event ended' : 'Started';
                }

                const totalSeconds = Math.floor(difference / 1000);
                const days = Math.floor(totalSeconds / 86400);
                const hours = Math.floor((totalSeconds % 86400) / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;

                if (days > 0) {
                    return `in ${days}d ${hours}h ${minutes}m ${seconds}s`;
                }

                if (hours > 0) {
                    return `in ${hours}h ${minutes}m ${seconds}s`;
                }

                if (minutes > 0) {
                    return `in ${minutes}m ${seconds}s`;
                }

                return `in ${seconds}s`;
            };

            const countdownElements = document.querySelectorAll('.event-start-countdown');
            const refreshCountdowns = () => {
                countdownElements.forEach((element) => {
                    const value = element.getAttribute('data-starts-at');
                    if (!value) {
                        return;
                    }

                    const hasEnded = element.getAttribute('data-has-ended') === 'true';
                    element.textContent = formatCountdown(new Date(value), hasEnded);
                });
            };

            const ticketsInput = document.getElementById('tickets');
            const ticketsMirror = document.getElementById('modalTicketsMirror');
            const purchaseForm = document.getElementById('purchaseForm');
            const validationMessage = document.getElementById('purchaseValidationMessage');
            const decisionButtons = document.querySelectorAll('[data-payment-decision]');

            refreshCountdowns();
            if (countdownElements.length > 0) {
                window.setInterval(refreshCountdowns, 1000);
            }

            if (!ticketsInput || !ticketsMirror || !purchaseForm) {
                return;
            }

            const syncTickets = () => {
                ticketsMirror.value = ticketsInput.value;
            };

            syncTickets();
            ticketsInput.addEventListener('input', syncTickets);

            decisionButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    syncTickets();

                    if (!purchaseForm.reportValidity()) {
                        validationMessage?.classList.remove('d-none');
                        return;
                    }

                    validationMessage?.classList.add('d-none');
                    document.getElementById('paymentDecision').value = button.getAttribute('data-payment-decision') || '';
                    purchaseForm.requestSubmit();
                });
            });
        })();
    </script>
}

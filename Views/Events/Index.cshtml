@model ASP_PROJECT.Models.ViewModels.EventListViewModel
@{
    ViewData["Title"] = "Events";
    ViewData["Action"] = "Index";
    ViewData["Controller"] = "Events";
    ViewData["RouteValues"] = new Dictionary<string, string>
    {
        ["searchTerm"] = Model.SearchTerm,
        ["categoryId"] = Model.CategoryId?.ToString() ?? string.Empty
    };
}

<section class="section-space">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="section-label">Catalog</span>
                <h1>Browse events</h1>
            </div>
        </div>
        <form method="get" class="card border-0 shadow-sm p-3 mb-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <input name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by title, city, or category" />
                </div>
                <div class="col-md-4">
                    <select name="categoryId" class="form-select">
                        <option value="">All categories</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">@category.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary">Apply</button>
                </div>
            </div>
        </form>

        <div class="row g-4">
            @foreach (var item in Model.Result.Items)
            {
                <div class="col-md-6 col-xl-4">
                    <partial name="_EventCard" model="item" />
                </div>
            }
        </div>

        <partial name="_PagedNavigation" model="Model.Result" />
    </div>
</section>

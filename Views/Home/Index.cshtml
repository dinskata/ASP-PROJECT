@model ASP_PROJECT.Models.ViewModels.EventListViewModel
@{
    ViewData["Title"] = "Home";
    var announcements = ViewData["Announcements"] as ASP_PROJECT.Models.ViewModels.AnnouncementListViewModel ?? new();
}

<partial name="_AnnouncementTicker" model="announcements" />

<section class="hero-section">
    <div class="container">
        <div class="hero-grid">
            <div class="hero-copy-block">
                <span class="hero-kicker">Curated events for ambitious people and active communities</span>
                <h1 class="hero-title mt-3">Find the next event worth leaving home for.</h1>
                <p class="lead hero-copy mt-3">Discover focused workshops, community gatherings, and professional sessions with clear details, polished booking flow, and a dashboard that keeps everything organized.</p>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    <a class="btn btn-primary btn-lg" asp-controller="Events" asp-action="Index">Browse Events</a>
                    <a class="btn btn-outline-light btn-lg" asp-controller="Venues" asp-action="Index">View Venues</a>
                </div>
                <div class="hero-inline-stats">
                    <div>
                        <strong>Fresh listings</strong>
                        <span>Browse live upcoming sessions</span>
                    </div>
                    <div>
                        <strong>Fast booking</strong>
                        <span>Register in a few clicks</span>
                    </div>
                    <div>
                        <strong>Clean admin flow</strong>
                        <span>Manage content with ease</span>
                    </div>
                </div>
            </div>
            <div class="hero-stage">
                <div class="hero-stage-card hero-stage-primary">
                    <div class="hero-stage-header">
                        <span class="badge bg-light text-dark">Featured this month</span>
                        <span class="hero-panel-label">Editor selection</span>
                    </div>
                    <h3>Modern ASP.NET Core Summit</h3>
                    <p>A practical day of architecture, security, and deployment sessions for students and developers building real web applications.</p>
                    <div class="hero-stage-meta">
                        <div><strong>Sofia</strong><span>Skyline Hall</span></div>
                        <div><strong>39 EUR</strong><span>Limited seats</span></div>
                    </div>
                </div>
                <div class="hero-stage-stack">
                    <div class="hero-stage-card hero-stage-secondary">
                        <span class="tiny-label">Why people stay</span>
                        <strong>Clean browsing</strong>
                        <p>Search by title, city, and category without clutter.</p>
                    </div>
                    <div class="hero-stage-card hero-stage-secondary accent-card">
                        <span class="tiny-label">After signup</span>
                        <strong>Your own dashboard</strong>
                        <p>Track registrations, manage activity, and return later.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-space home-highlight-band">
    <div class="container">
        <div class="highlight-grid">
            <div class="highlight-intro">
                <span class="section-label">Featured events</span>
                <h2>Upcoming opportunities with a clearer focus.</h2>
                <p class="text-secondary">Instead of a crowded listing wall, the home page now introduces the platform, then moves directly into a curated set of events people can act on.</p>
                <a class="btn btn-sm btn-outline-primary mt-2" asp-controller="Events" asp-action="Index">See all events</a>
            </div>
            <div class="highlight-side-card">
                <span class="tiny-label">Platform feel</span>
                <h4>Designed to feel like a product, not a checklist.</h4>
                <p class="mb-0">The layout now prioritizes rhythm, whitespace, and stronger grouping so every section feels intentional.</p>
            </div>
        </div>
        <div class="row g-4">
            @foreach (var item in Model.Result.Items)
            {
                <div class="col-md-6 col-xl-4">
                    <partial name="_EventCard" model="item" />
                </div>
            }
        </div>
    </div>
</section>

<section class="section-space editorial-section">
    <div class="container">
        <div class="editorial-grid">
            <div class="editorial-copy">
                <span class="section-label">How it flows</span>
                <h2>Discovery, booking, and follow-up are separated into simple steps.</h2>
                <p class="text-secondary">Visitors land on a clear homepage, move into richer event details, register through individual accounts, and return to a personal dashboard without the site feeling overloaded.</p>
            </div>
            <div class="editorial-note">
                <strong>Better first impression</strong>
                <p class="mb-0">More contrast, fewer “assignment” callouts, and a stronger visual story from top to bottom.</p>
            </div>
        </div>
        <div class="journey-grid">
            <div class="journey-card">
                <span>01</span>
                <h5>Explore</h5>
                <p>Open the catalog, compare event types, and find the right session fast.</p>
            </div>
            <div class="journey-card">
                <span>02</span>
                <h5>Register</h5>
                <p>Create an account and reserve seats through a cleaner, more polished flow.</p>
            </div>
            <div class="journey-card">
                <span>03</span>
                <h5>Return</h5>
                <p>Use the dashboard to manage activity and come back for the next event.</p>
            </div>
        </div>
    </div>
</section>

<section class="section-space soft-panel value-section">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="section-label">What makes it useful</span>
                <h2>Core features presented with less noise.</h2>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-4"><div class="feature-card"><h5>Secure registration</h5><p>Validated forms, antiforgery protection, and role-based access for a safer user flow.</p></div></div>
            <div class="col-md-4"><div class="feature-card"><h5>Admin control</h5><p>Area-based administration for editing, publishing, and maintaining the event catalog.</p></div></div>
            <div class="col-md-4"><div class="feature-card"><h5>Search and paging</h5><p>Visitors can filter events and browse venue pages without overwhelming long lists.</p></div></div>
        </div>
        <div class="value-strip">
            <div><strong>Identity accounts</strong><span>Register, log in, and keep activity personal</span></div>
            <div><strong>Event reviews</strong><span>Attendees can leave feedback after participating</span></div>
            <div><strong>Responsive layout</strong><span>Works better across desktop, tablet, and mobile</span></div>
            <div><strong>Clean UI language</strong><span>More editorial, less generic template</span></div>
        </div>
    </div>
</section>
            </div>
        </div>
    </div>
</section>

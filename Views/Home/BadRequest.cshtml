@model ASP_PROJECT.Models.ErrorViewModel
@{
    ViewData["Title"] = "Bad Request";
}

<section class="section-space">
    <div class="container narrow-content text-center">
        <span class="display-1 fw-semibold text-warning">400</span>
        <h1>@Model.Title</h1>
        <p class="text-secondary">@Model.Message</p>
        <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
            <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Return Home</a>
            <a class="btn btn-outline-primary" asp-controller="Home" asp-action="Contact">Contact support</a>
        </div>
    </div>
</section>

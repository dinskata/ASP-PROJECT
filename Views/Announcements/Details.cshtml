@model ASP_PROJECT.Models.Announcement
@{
    ViewData["Title"] = Model.Title;
}

<section class="section-space">
    <div class="container narrow-content">
        <span class="section-label">@Model.Audience</span>
        <h1>@Model.Title</h1>
        <p class="text-secondary">@Model.PublishedOnUtc.ToLocalTime().ToString("f")</p>
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <p class="mb-0">@Model.Content</p>
            </div>
        </div>
    </div>
</section>

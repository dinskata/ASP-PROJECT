@using System.Globalization
@model ASP_PROJECT.Models.ViewModels.AnnouncementListViewModel
@{
    ViewData["Title"] = "Announcements";
}

<section class="section-space">
    <div class="container announcements-page">
        <div class="section-heading announcements-heading">
            <div>
                <span class="section-label">Updates</span>
                <h1>Announcements</h1>
            </div>
        </div>
        <div class="row g-4 justify-content-center announcements-layout">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100 announcements-card">
                    <div class="card-body announcements-card-body">
                        <h3 class="h5">Pinned</h3>
                        @if (Model.Pinned.Any())
                        {
                            @foreach (var item in Model.Pinned)
                            {
                                <div class="announcement-entry">
                                    <a asp-action="Details" asp-route-id="@item.Id">@item.Title</a>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="announcement-empty mb-0">No pinned announcements right now.</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm announcements-card">
                    <div class="card-body announcements-card-body">
                        <h3 class="h5">Recent</h3>
                        @if (Model.Recent.Any())
                        {
                            @foreach (var item in Model.Recent)
                            {
                                <div class="announcement-entry">
                                    <div class="announcement-entry-header">
                                        <a asp-action="Details" asp-route-id="@item.Id">@item.Title</a>
                                        <span class="text-secondary small">@item.PublishedOnUtc.ToLocalTime().ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</span>
                                    </div>
                                    <p class="mb-0 text-secondary">@item.Content</p>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="announcement-empty mb-0">No recent announcements yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

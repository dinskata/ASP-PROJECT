@model ASP_PROJECT.Models.ViewModels.EventListItemViewModel

<article class="card h-100 border-0 shadow-sm event-card">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <span class="badge text-bg-light">@Model.Category</span>
            <span class="small text-secondary">@Model.StartsAtUtc.ToLocalTime().ToString("dd MMM yyyy")</span>
        </div>
        <h5 class="card-title">@Model.Title</h5>
        <p class="text-secondary mb-3">@Model.Venue, @Model.City</p>
        <div class="mt-auto d-flex justify-content-between align-items-center">
            <div>
                <div class="fw-semibold">@(Model.Price == 0 ? "Free" : $"{Model.Price:F2} BGN")</div>
                <small class="text-secondary">@Model.SeatsAvailable seats left</small>
            </div>
            <a class="btn btn-outline-primary" asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id">Open</a>
        </div>
    </div>
</article>

@model ASP_PROJECT.Models.ViewModels.EventListItemViewModel

<article class="card h-100 border-0 shadow-sm event-card">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <span class="badge text-bg-light">@Model.Category</span>
            <div class="text-end">
                <span class="badge @(Model.HasEnded ? "text-bg-secondary" : "text-bg-success")">
                    @(Model.HasEnded ? "Ended" : "Upcoming")
                </span>
                <div class="small text-secondary mt-2">@Model.StartsAtUtc.ToLocalTime().ToString("dd MMM yyyy")</div>
            </div>
        </div>
        <h5 class="card-title">@Model.Title</h5>
        <p class="text-secondary mb-3">@Model.Venue, @Model.City</p>
        <div class="mt-auto d-flex justify-content-between align-items-center">
            <div>
                <div class="fw-semibold">@(Model.Price == 0 ? "Free" : $"EUR {Model.Price:F2}")</div>
                @if (Model.HasEnded)
                {
                    <small class="text-secondary">
                        @(Model.ReviewCount == 0
                            ? "No reviews yet"
                            : $"{Model.AverageRating:F1}/5 from {Model.ReviewCount} review{(Model.ReviewCount == 1 ? string.Empty : "s")}")
                    </small>
                }
                else
                {
                    <small class="text-secondary">@Model.SeatsAvailable seats left</small>
                }
            </div>
            <a class="btn btn-outline-primary" asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id">Open</a>
        </div>
    </div>
</article>

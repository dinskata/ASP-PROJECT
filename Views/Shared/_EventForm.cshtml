@model ASP_PROJECT.Models.ViewModels.EventEditViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

<div class="editor-intro mb-4">
    <h2 class="h5 mb-2">Event details</h2>
    <p class="text-secondary mb-0">Set the event basics, choose the venue, and pick a start time that fits your schedule.</p>
</div>

<div class="row g-4 editor-grid">
    <div class="col-lg-6">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="col-lg-3 col-md-6">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"></select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>
    <div class="col-lg-3 col-md-6">
        <label asp-for="VenueId" class="form-label"></label>
        <select asp-for="VenueId" class="form-select" asp-items="@(new SelectList(Model.Venues, "Id", "Name"))"></select>
        <span asp-validation-for="VenueId" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="6"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="col-lg-4 col-md-6">
        <label asp-for="StartsAtUtc" class="form-label"></label>
        <input asp-for="StartsAtUtc" class="form-control" type="datetime-local" />
        <small class="form-text text-secondary">Choose the local start date and time for attendees.</small>
        <span asp-validation-for="StartsAtUtc" class="text-danger"></span>
    </div>
    <div class="col-lg-2 col-md-6">
        <label asp-for="DurationMinutes" class="form-label"></label>
        <input asp-for="DurationMinutes" class="form-control" />
        <span asp-validation-for="DurationMinutes" class="text-danger"></span>
    </div>
    <div class="col-lg-3 col-md-6">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="col-lg-3 col-md-6">
        <label asp-for="SeatsAvailable" class="form-label"></label>
        <input asp-for="SeatsAvailable" class="form-control" />
        <span asp-validation-for="SeatsAvailable" class="text-danger"></span>
    </div>
    <div class="col-12">
        <div class="editor-publish-row">
            <div>
                <h3 class="h6 mb-1">Visibility</h3>
                <p class="text-secondary small mb-0">Publish the event now or keep it hidden until the details are final.</p>
            </div>
            <div class="form-check editor-toggle mb-0">
                <input asp-for="IsPublished" class="form-check-input" />
                <label asp-for="IsPublished" class="form-check-label"></label>
            </div>
        </div>
    </div>
</div>

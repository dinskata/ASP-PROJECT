@model dynamic
@{
    var action = ViewData["Action"]?.ToString() ?? "Index";
    var controller = ViewData["Controller"]?.ToString();
    var baseRouteValues = ViewData["RouteValues"] as Dictionary<string, string> ?? new Dictionary<string, string>();
    var previousRouteValues = new Dictionary<string, string>(baseRouteValues)
    {
        ["page"] = (Model.PageNumber - 1).ToString()
    };
    var nextRouteValues = new Dictionary<string, string>(baseRouteValues)
    {
        ["page"] = (Model.PageNumber + 1).ToString()
    };
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mt-4">
            <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
                @if (Model.HasPreviousPage)
                {
                    <a class="page-link" href="@Url.Action(action, controller, previousRouteValues)">Previous</a>
                }
                else
                {
                    <span class="page-link">Previous</span>
                }
            </li>
            <li class="page-item disabled"><span class="page-link">Page @Model.PageNumber of @Model.TotalPages</span></li>
            <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
                @if (Model.HasNextPage)
                {
                    <a class="page-link" href="@Url.Action(action, controller, nextRouteValues)">Next</a>
                }
                else
                {
                    <span class="page-link">Next</span>
                }
            </li>
        </ul>
    </nav>
}

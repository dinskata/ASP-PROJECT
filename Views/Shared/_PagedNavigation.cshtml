@model dynamic
@{
    var action = ViewData["Action"]?.ToString() ?? "Index";
    var controller = ViewData["Controller"]?.ToString();
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mt-4">
            <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
                <a class="page-link"
                   asp-action="@action"
                   asp-controller="@controller"
                   asp-route-page="@(Model.PageNumber - 1)"
                   asp-all-route-data="@(ViewData["RouteValues"] as Dictionary<string, string> ?? new Dictionary<string, string>())">Previous</a>
            </li>
            <li class="page-item disabled"><span class="page-link">Page @Model.PageNumber of @Model.TotalPages</span></li>
            <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
                <a class="page-link"
                   asp-action="@action"
                   asp-controller="@controller"
                   asp-route-page="@(Model.PageNumber + 1)"
                   asp-all-route-data="@(ViewData["RouteValues"] as Dictionary<string, string> ?? new Dictionary<string, string>())">Next</a>
            </li>
        </ul>
    </nav>
}

@using ASP_PROJECT.Data
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eventure</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ASP_PROJECT.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">Eventure</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="mainNav" class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Events" asp-action="Index">Events</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Venues" asp-action="Index">Venues</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Announcements" asp-action="Index">Announcements</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">My Dashboard</a></li>
                        }
                        @if (User.IsInRole(DbInitializer.AdministratorRole))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a></li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main>
        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="container pt-3">
                <div class="alert alert-info shadow-sm mb-0">@statusMessage</div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-3">
            <div>
                <h6 class="mb-1">Eventure</h6>
                <p class="mb-0">Conference and workshop management platform built with ASP.NET Core MVC.</p>
            </div>
            <div class="text-md-end">
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                <span class="mx-2">|</span>
                <a asp-controller="Home" asp-action="Contact">Contact</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

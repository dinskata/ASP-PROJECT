@using ASP_PROJECT.Data
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eventure</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ASP_PROJECT.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="site-backdrop"></div>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand brand-lockup" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">E</span>
                    <span class="fw-semibold">Eventure</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="mainNav" class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Events" asp-action="Index">Events</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Venues" asp-action="Index">Venues</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Announcements" asp-action="Index">Announcements</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">About</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Contact">Contact</a></li>
                        @if (User.IsInRole(DbInitializer.VenueManagerRole)
                            || User.IsInRole(DbInitializer.VenueStaffRole)
                            || User.IsInRole(DbInitializer.SiteModeratorRole)
                            || User.IsInRole(DbInitializer.AdministratorRole))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="TicketVerification" asp-action="Index">Ticket Verification</a></li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main class="site-main">
        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="container pt-3">
                <div class="alert alert-info shadow-sm mb-0">@statusMessage</div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container text-center">
            <h6 class="mb-0">Eventure</h6>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
